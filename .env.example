# ============================================================
# INSTAGRAM MARKETING INTELLIGENCE DASHBOARD — ENV TEMPLATE
# Copy this file to .env.local and fill in your values
# ============================================================

# ----- DEV TOGGLE -----
# Set to "true" to skip all live API calls and use mock fixtures
# Safe for development without production API keys
USE_MOCK_DATA=true

# ----- DATABASE -----
# Supabase PostgreSQL connection string (use pooler URL for serverless)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/instagram_dashboard"
# Direct connection URL (used by Prisma migrations, not pooled)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/instagram_dashboard"

# ----- SUPABASE -----
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ----- CLERK AUTH -----
# Found in: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ----- AI PROVIDERS -----
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
# Primary model for analysis and script generation
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# OpenAI Whisper (audio transcription) — https://platform.openai.com/
OPENAI_API_KEY="sk-..."

# Google Gemini (multimodal video analysis) — https://aistudio.google.com/
GOOGLE_API_KEY="AIza..."

# ----- VECTOR DATABASE -----
# Pinecone — https://app.pinecone.io/
PINECONE_API_KEY="pcsk_..."
PINECONE_INDEX_NAME="instagram-content-patterns"
PINECONE_ENVIRONMENT="us-east-1"

# ----- REDIS / UPSTASH -----
# Upstash Redis — https://console.upstash.com/
# For local Docker dev use: redis://:redis_password@localhost:6379
REDIS_URL="redis://:redis_password@localhost:6379"
UPSTASH_REDIS_REST_URL="https://your-upstash.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ----- META / INSTAGRAM APIs -----
# Meta App credentials — https://developers.facebook.com/apps/
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
# Redirect URI registered in Meta App Dashboard
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/instagram/callback"

# ----- APIFY -----
# Third-party ethical Instagram scraper — https://apify.com/
APIFY_API_TOKEN="apify_api_..."
# Actor ID for Instagram profile scraper
APIFY_INSTAGRAM_ACTOR_ID="apify/instagram-scraper"

# ----- STRIPE -----
# Stripe payments — https://dashboard.stripe.com/
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from your Stripe Dashboard
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."

# ----- APP CONFIG -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:8000"
# Internal secret for web → FastAPI calls
INTERNAL_API_SECRET="change-me-in-production-use-openssl-rand-hex-32"

# ----- SENTRY (Error Monitoring) -----
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="sntrys_..."
